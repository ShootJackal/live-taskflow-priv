{
  "name": "taskflow",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start-web": "expo start --web",
    "start-web:tunnel": "expo start --web --tunnel",
    "start-web-dev": "DEBUG=expo* expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "prepare:web": "node scripts/prepare-pwa.js",
    "build:web": "npm run prepare:web && expo export --platform web",
    "build": "npm run build:web",
    "vercel-build": "node scripts/generate-version.js && npm run build:web"
  },
  "dependencies": {
    "@expo-google-fonts/lexend": "0.4.1",
    "@nkzw/create-context-hook": "1.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "5.83.0",
    "@vercel/speed-insights": "^2.0.0",
    "expo": "54.0.27",
    "expo-constants": "18.0.13",
    "expo-font": "14.0.10",
    "expo-haptics": "15.0.8",
    "expo-image": "3.0.11",
    "expo-linking": "8.0.10",
    "expo-router": "6.0.17",
    "expo-splash-screen": "31.0.12",
    "expo-status-bar": "3.0.9",
    "lucide-react-native": "0.475.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "2.28.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.5.1",
    "@vercel/speed-insights": "2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.10",
    "@vercel/node": "^5.6.12",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": "22.x"
  },
  "private": true
}
