# Copy this file to `.env.local` for local runs (or set in Vercel project settings).

# Your single Google Apps Script deployment URL:
EXPO_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Optional split-endpoint setup (advanced):
# EXPO_PUBLIC_GAS_CORE_URL=https://script.google.com/macros/s/REPLACE_WITH_CORE_ID/exec
# EXPO_PUBLIC_GAS_ANALYTICS_URL=https://script.google.com/macros/s/REPLACE_WITH_ANALYTICS_ID/exec

# ── ADMIN PASSWORD ──────────────────────────────────────────────────────────
# DO NOT put your admin password here or in any EXPO_PUBLIC_ variable.
# EXPO_PUBLIC_ variables are baked into the public JS bundle and visible
# to anyone who inspects the built files.
#
# Instead, store your admin password in Google Apps Script:
#   Extensions → Apps Script → Project Settings → Script Properties
#   Add: ADMIN_PASSWORD = <your password>
#   Add: ADMIN_HMAC_SECRET = <run: openssl rand -hex 32 to generate>
#
# The app sends the password to GAS, which validates it server-side and
# returns a signed 24-hour token. Nothing sensitive ever touches the bundle.
