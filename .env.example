# Copy this file to `.env.local` for local runs (or set in Vercel project settings).
# Recommended monolith setup (single Apps Script deployment):
EXPO_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Optional split-endpoint setup:
# EXPO_PUBLIC_GAS_CORE_URL=https://script.google.com/macros/s/REPLACE_WITH_CORE_DEPLOYMENT_ID/exec
# EXPO_PUBLIC_GAS_ANALYTICS_URL=https://script.google.com/macros/s/REPLACE_WITH_ANALYTICS_DEPLOYMENT_ID/exec
