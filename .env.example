# =============================================================================
# TaskFlow — Environment Variables Reference
# =============================================================================
# For local dev: copy this file to .env.local and fill in your values.
# For Vercel:    set these in Project Settings → Environment Variables.
# =============================================================================


# -----------------------------------------------------------------------------
# CLIENT-SIDE (EXPO_PUBLIC_) — baked into the JS bundle at build time
# -----------------------------------------------------------------------------

# GAS endpoint for the app (single monolith deployment).
# Used by the native app and as a fallback on web if the CDN proxy is down.
EXPO_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Optional: split Core + Analytics endpoints for higher GAS throughput.
# If set, these take precedence over EXPO_PUBLIC_GOOGLE_SCRIPT_URL for routing.
# EXPO_PUBLIC_GAS_CORE_URL=https://script.google.com/macros/s/REPLACE_WITH_CORE_ID/exec
# EXPO_PUBLIC_GAS_ANALYTICS_URL=https://script.google.com/macros/s/REPLACE_WITH_ANALYTICS_ID/exec

# Admin password for the Tools panel.
# ⚠️  EXPO_PUBLIC_ vars are visible in the client JS bundle.
#     For better security, validate admin auth server-side in your GAS script
#     instead of relying solely on this value.
EXPO_PUBLIC_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD


# -----------------------------------------------------------------------------
# SERVER-SIDE (Vercel only) — never sent to the browser
# -----------------------------------------------------------------------------

# GAS endpoint used by the /api/gas CDN proxy and /api/warm cron.
# Set this in Vercel → Project Settings → Environment Variables (no EXPO_PUBLIC_ prefix).
# If omitted, the proxy falls back to EXPO_PUBLIC_GOOGLE_SCRIPT_URL.
#
# Setting GAS_SCRIPT_URL means your GAS URL is never in the client bundle at all
# when users are on the Vercel-hosted web app (proxy handles all read calls).
GAS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec
